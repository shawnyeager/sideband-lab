---
import Base from '../layouts/Base.astro';
---

<Base title="Not Found" description="The page you're looking for doesn't exist." canonicalUrl="https://lab.sideband.pub/">
  <div class="not-found">
    <span class="not-found__code">404</span>
    <div class="not-found__signal" aria-hidden="true"></div>
    <p>No signal at this frequency.</p>
    <a href="/" class="not-found__back"><svg class="not-found__back-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.5 8H3.5M7 4 3.5 8 7 12"></path></svg>All projects</a>
  </div>
</Base>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    text-align: center;
    gap: var(--space-xs);
  }

  .not-found__code {
    font-family: var(--font-display);
    font-weight: var(--display-weight);
    font-size: clamp(3rem, 8vw, 5rem);
    color: var(--text);
    opacity: 0.06;
    line-height: 1;
    margin-bottom: var(--space-sm);
  }

  .not-found__signal {
    width: min(280px, 60vw);
    height: 1px;
    background: var(--text-sub);
    margin-bottom: var(--space-sm);
    transform-origin: left center;
    animation: flatline 1.5s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  @keyframes flatline {
    from { transform: scaleX(0); }
    to { transform: scaleX(1); }
  }

  .not-found p {
    font-size: 0.95rem;
    color: var(--text-muted);
  }

  .not-found__back {
    margin-top: var(--space-sm);
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-sub);
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  .not-found__back-icon {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .not-found__signal {
      animation: none;
    }
  }
</style>
