---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getActiveProjects } from '../lib/utils';
import projects from '../content/projects.json';

const activeProjects = getActiveProjects(projects);
const [featured, ...rest] = activeProjects;
---

<Base>
  {featured ? (
    <div class="projects">
      <ProjectCard
        slug={featured.slug}
        title={featured.title}
        description={featured.description}
        date={featured.date}
        substackUrl={featured.substackUrl}
        substackTitle={featured.substackTitle}
        thumbnail={featured.thumbnail}
        featured={true}
      />
      {rest.length > 0 && (
        <div class="project-list">
          {rest.map(project => (
            <ProjectCard
              slug={project.slug}
              title={project.title}
              description={project.description}
              date={project.date}
              substackUrl={project.substackUrl}
              substackTitle={project.substackTitle}
              thumbnail={project.thumbnail}
            />
          ))}
        </div>
      )}
    </div>
  ) : (
    <div class="empty-state">
      <p>Projects coming soon.</p>
    </div>
  )}
</Base>

<style>
  .projects {
    display: flex;
    flex-direction: column;
    max-width: 860px;
    margin: 0 auto;
  }

  .project-list {
    display: flex;
    flex-direction: column;
  }

  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 30vh;
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--text-sub);
  }
</style>
