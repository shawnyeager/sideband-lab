---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getActiveProjects } from '../lib/utils';
import projects from '../content/projects.json';

const activeProjects = getActiveProjects(projects);
const featured = activeProjects.find(p => p.featured) || activeProjects[0];
const rest = activeProjects.filter(p => p !== featured);

// Group remaining projects by year
const byYear = new Map<string, typeof rest>();
rest.forEach(p => {
  const year = p.date.slice(0, 4);
  if (!byYear.has(year)) byYear.set(year, []);
  byYear.get(year)!.push(p);
});
const years = [...byYear.keys()];
---

<Base
  description="AI is reshaping everything. Sideband is the signal underneath—control, trust, money, and who wins. The lab is where those ideas become something you can see."
>
  {featured ? (
    <div class="projects">
      <ProjectCard
        slug={featured.slug}
        title={featured.title}
        description={featured.description}
        date={featured.date}
        substackUrl={featured.substackUrl}
        substackTitle={featured.substackTitle}
        thumbnail={featured.thumbnail}
        featured={true}
      />
      {years.map((year, i) => (
        <>
          {i > 0 && <h3 class="year-label">{year}</h3>}
          <div class="project-grid">
            {byYear.get(year)!.map(project => (
              <ProjectCard
                slug={project.slug}
                title={project.title}
                description={project.description}
                date={project.date}
                substackUrl={project.substackUrl}
                substackTitle={project.substackTitle}
                thumbnail={project.thumbnail}
              />
            ))}
          </div>
        </>
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <p>Projects coming soon.</p>
    </div>
  )}
</Base>

<style is:global>
  .projects {
    display: flex;
    flex-direction: column;
    max-width: 860px;
    margin: 0 auto;
  }

  .project-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    border-top: 1px solid var(--hr);
    padding-top: var(--space-lg);
  }

  .year-label {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-sub);
    margin: var(--space-lg) 0 0;
  }

  .empty-state {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 30vh;
    font-family: var(--font-display);
    font-size: 1.125rem;
    color: var(--text-sub);
  }

  @media (max-width: 640px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
