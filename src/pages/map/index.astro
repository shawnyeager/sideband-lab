---
import { projectMeta, projectHeader, fontPreload } from '../../lib/header';
import projects from '../../content/projects.json';
import AgentInfraMap from '../../components/map/AgentInfraMap';
import mapData from '../../../data/map-data.json';

const baseProject = projects.find(p => p.slug === 'map');
// Keep schema dateModified / article:modified_time in sync with the data export,
// so the "Updated" date on the page and in structured data share one source.
const project = baseProject ? { ...baseProject, dateModified: mapData.exported_at } : null;
const meta = project ? projectMeta(project) : '';
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <Fragment set:html={fontPreload} />
  <Fragment set:html={meta} />
  <style is:global>
    @font-face {
      font-family: 'Space Grotesk';
      src: url('/fonts/SpaceGrotesk-Variable.woff2') format('woff2');
      font-weight: 300 700;
      font-style: normal;
      font-display: swap;
    }
    /* <main> is a semantic landmark only; display:contents keeps layout unchanged. */
    #main-content { display: contents; }
    /* Honor reduced-motion: neutralize the island's inline-style transitions. */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        transition-duration: 0.01ms !important;
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        scroll-behavior: auto !important;
      }
    }
  </style>
</head>
<body style="margin:0; background:#eeebe4;">
  <Fragment set:html={projectHeader} />
  <main id="main-content">
    <h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0;">Agent-Era Infrastructure Map—openness scoring across five layers of the agent stack</h1>
    <AgentInfraMap client:load />
  </main>
</body>
</html>
