---
/**
 * Layout for project pages that embed raw HTML from public/.
 * Goes through Astro's normal rendering pipeline (unlike raw Response),
 * so HMR works and View Transitions apply.
 */
import { projectHeader, fontPreload, projectMeta, projectEssayCTA } from '../lib/header';
import projects from '../content/projects.json';

interface Props {
  slug: string;
  headContent: string;
  bodyContent: string;
}

const { slug, headContent, bodyContent } = Astro.props;
const project = projects.find(p => p.slug === slug);
const meta = project ? projectMeta(project) : '';
const essayCTA = project ? projectEssayCTA(project) : '';

let finalBody = bodyContent;

// Inject companion-essay CTA in place of hr-subtle (between prose and disclosures)
if (essayCTA) {
  if (finalBody.includes('<div class="hr-subtle"></div>')) {
    finalBody = finalBody.replace(
      '<div class="hr-subtle"></div>',
      essayCTA
    );
  } else if (finalBody.includes('<div class="project-credit">')) {
    finalBody = finalBody.replace(
      '<div class="project-credit">',
      `${essayCTA}<div class="project-credit">`
    );
  }
}
---

<html lang="en">
<head>
  <Fragment set:html={fontPreload} />
  <Fragment set:html={meta} />
  <Fragment set:html={headContent} />
</head>
<body style="margin:0; background:#eeebe4;">
  <Fragment set:html={projectHeader} />
  <Fragment set:html={finalBody} />
</body>
</html>
