---
/**
 * Homepage header — Substack-style: logo left, wordmark centered, GitHub right.
 * Project pages use the smaller `projectHeader` from src/lib/header.ts instead.
 */
---

<header class="home-header">
  <div class="home-header__left">
    <a href="/" class="home-header__logo">
      <img src="/img/sideband-icon.png" alt="Sideband Lab" width="40" height="40" loading="eager" />
    </a>
  </div>
  <div class="home-header__center">
    <a href="/" class="home-header__wordmark">
      <img src="/img/sideband-wordmark.png" alt="Sideband Lab" height="36" />
    </a>
  </div>
  <div class="home-header__right">
    <a href="https://www.sideband.pub" class="home-header__back plausible-event-name=Outbound+Sideband">&larr; sideband.pub</a>
    <a href="https://github.com/shawnyeager/sideband-lab" class="home-header__github plausible-event-name=Outbound+GitHub" aria-label="View source on GitHub">
      <svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
    </a>
  </div>
</header>

<style>
  .home-header {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 87px;
    padding: 0 20px;
    border-bottom: 1px solid var(--hr);
  }

  .home-header__left {
    justify-self: start;
    padding-left: 5px;
  }

  .home-header__logo {
    display: flex;
  }

  .home-header__logo img {
    border-radius: 6px;
    color: transparent;
  }

  .home-header__center {
    justify-self: center;
  }

  .home-header__wordmark {
    display: flex;
    text-decoration: none;
  }

  .home-header__wordmark img {
    height: 34px;
    width: auto;
    color: transparent;
  }

  .home-header__right {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .home-header__back {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--text-muted);
    text-decoration: none;
  }

  .home-header__github {
    color: var(--text-muted);
    text-decoration: none;
    display: flex;
  }

  .home-header__github svg {
    width: 20px;
    height: 20px;
  }

  @media (max-width: 640px) {
    .home-header {
      height: 60px;
      padding: 0 12px;
    }

    .home-header__logo img {
      width: 28px;
      height: 28px;
    }

    .home-header__wordmark img {
      height: 24px;
    }

    .home-header__back {
      display: none;
    }

    .home-header__github svg {
      width: 18px;
      height: 18px;
    }
  }
</style>
