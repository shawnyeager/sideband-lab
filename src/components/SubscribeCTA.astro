---
---

<div class="subscribe">
  <div class="subscribe__rule"></div>
  <p class="subscribe__prompt">Get the next one in your inbox</p>
  <a
    href="https://www.sideband.pub/subscribe"
    class="subscribe__btn plausible-event-name=Subscribe+Click"
  >
    Subscribe
  </a>
</div>

<style>
  .subscribe {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-lg) 0 var(--space-md);
  }

  .subscribe__rule {
    width: 40px;
    height: 1px;
    background: var(--hr);
    margin-bottom: var(--space-xs);
  }

  .subscribe__prompt {
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    color: var(--text-sub);
  }

  .subscribe__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 24px;
    background: var(--cta-bg);
    color: var(--cta-fg);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 16px;
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: 8px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .subscribe__btn:hover {
    background: var(--cta-bg-hover);
    color: var(--cta-fg-hover);
  }

  .subscribe__btn:active {
    background: var(--cta-bg-active);
    transform: translateY(1px);
  }

  .subscribe__btn:focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 3px;
  }

  @media (max-width: 640px) {
    .subscribe {
      padding: var(--space-md) 0 var(--space-sm);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .subscribe__btn {
      transition: none;
    }
    .subscribe__btn:active {
      transform: none;
    }
  }
</style>
