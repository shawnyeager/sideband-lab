---
import SubscribeCTA from './SubscribeCTA.astro';
---

<footer class="site-footer">
  <SubscribeCTA />
  <p class="site-footer__copy">
    AI is reshaping everything. <a href="https://www.sideband.pub">Sideband</a> is the signal underneath—control, trust, money, and who wins. The lab is where those ideas become something you can see. 30 years taking frontier tech to market, from browsers to Bitcoin. I map what's coming.
  </p>
  <p class="site-footer__open-source">
    This site is open source — <a href="https://github.com/shawnyeager/sideband-lab">view on GitHub</a>.
  </p>
</footer>

<style>
  .site-footer {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px 48px;
  }

  .site-footer__copy {
    max-width: 540px;
    margin: var(--space-sm) auto 0;
    font-size: 0.95rem;
    line-height: 1.7;
    text-align: center;
    color: var(--text-muted);
  }

  .site-footer__copy a {
    color: var(--text-muted);
    border-bottom: 1px solid var(--hr);
    transition: color 0.15s, border-color 0.15s;
  }

  .site-footer__copy a:hover {
    color: var(--text);
    border-color: var(--text);
  }

  .site-footer__open-source {
    margin-top: 12px;
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    text-align: center;
    color: var(--text-sub);
  }

  .site-footer__open-source a {
    color: var(--text-sub);
    border-bottom: 1px solid var(--hr);
    transition: color 0.15s, border-color 0.15s;
  }

  .site-footer__open-source a:hover {
    color: var(--text);
    border-color: var(--text);
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 0 16px 32px;
    }

    .site-footer__copy {
      font-size: 0.8rem;
      line-height: 1.6;
      color: var(--text-sub);
    }
  }
</style>
